# ─── Aplicação ───────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Banco de Dados ───────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=buscas_leilao
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/buscas_leilao

# ─── Redis / Celery ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Scraping / Proxies ───────────────────────────────────
# Deixe em branco para rodar sem proxy (limitado, pode ser bloqueado)
PROXY_LIST=
# Ex: http://user:pass@proxy1.host:port,http://user:pass@proxy2.host:port

# ─── Notificações ─────────────────────────────────────────
# WhatsApp via Evolution API (self-hosted) ou Twilio
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alertas@buscasleilao.com.br

# ─── Alertas ──────────────────────────────────────────────
# Score mínimo para disparar alerta (0-100)
ALERT_MIN_SCORE=70
# Desconto mínimo para alertar (%)
ALERT_MIN_DISCOUNT=25

# ─── Geocodificação ───────────────────────────────────────
# Google Maps Geocoding API (opcional, melhora precisão)
GOOGLE_MAPS_API_KEY=
